# ═══════════════════════════════════════════════════════════
# NOIR·ESSENCE — Variables de entorno
# 1. Copia este archivo: cp .env.example .env.local
# 2. Llena cada valor con tus credenciales reales
# 3. NUNCA subas .env.local a git
# ═══════════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────────
# supabase.com → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Stripe ───────────────────────────────────────────────
# dashboard.stripe.com → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# dashboard.stripe.com → Developers → Webhooks → tu endpoint
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Brevo ────────────────────────────────────────────────
# app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=xkeysib-...
BREVO_SENDER_EMAIL=hola@noiressence.co
BREVO_SENDER_NAME=NOIR·ESSENCE

# ── Cloudinary ───────────────────────────────────────────
# cloudinary.com → Dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=noir-essence
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# ── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://noir-essence.vercel.app
NEXT_PUBLIC_APP_NAME=NOIR·ESSENCE
